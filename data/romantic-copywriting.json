  "copywritings": [
    {
      "id": 1,
      "content": "我溼了，想要",
      "length": 6,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 2,
      "content": "無論是生活還是性生活，都要靠自己勤勞的雙手來創造 ",
      "length": 25,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 3,
      "content": "空有一顆擼管的心，上帝卻給了我一個大姨媽的身體。 ",
      "length": 25,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 4,
      "content": "朋友你今天就要遠走，請幹了這白妞。",
      "length": 17,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 5,
      "content": "你還是走吧，就當沒有我這個小炮友。 ",
      "length": 18,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 6,
      "content": "我跟你說過多少次了，抱怨沒用，你得抱我",
      "length": 19,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 7,
      "content": "當女朋友單膝跪地的時候，我習慣性的脫了褲子…",
      "length": 22,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 8,
      "content": "說幹就幹，來把衣服脫了",
      "length": 11,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 9,
      "content": "不說話，直接發一段呻吟聲的微信語音給他。 ",
      "length": 21,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 10,
      "content": "聽人說，女人是水做的。所以我一直以為，那涓涓的流水一定很美 ",
      "length": 30,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 11,
      "content": "想做你的太陽，開心的時候溫暖你，不開心的時候日死你。 ",
      "length": 27,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 12,
      "content": "“你猜我什麼血型？” “你是我的理想型” ",
      "length": 21,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 13,
      "content": "你再這樣，我就要拿小皮鞭打你了 ",
      "length": 16,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 14,
      "content": "三觀一致的人，是就連聊汙話，都能聊得很汙很汙的人。 ",
      "length": 26,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 15,
      "content": "你別難過，風箏有風，海豚有海，你還有我。 ",
      "length": 21,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 16,
      "content": "眾生皆苦只有你是草莓味的 ",
      "length": 13,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 17,
      "content": "對你就像喝酒，總想先乾為敬 ",
      "length": 14,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 18,
      "content": "含緊點,撅起來 ",
      "length": 8,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 19,
      "content": "網上女人都說他們玩累了就找個老實人嫁了，呵呵，她們什麼時候玩累，我都等不及了 ",
      "length": 39,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 20,
      "content": "有人說我脾氣差 真是笑死了 我長這麼好看脾氣好還得了",
      "length": 26,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 21,
      "content": "讓我住進你心裡 或者你的被窩裡 ",
      "length": 16,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 22,
      "content": "小擼怡情，大擼傷身，強擼灰飛煙滅 先撕長裙，後撕內褲，百撕不得其解",
      "length": 33,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 23,
      "content": "我要和你做盡豔情之事",
      "length": 10,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 24,
      "content": "怕什麼真理無窮，進一寸有一寸的歡喜",
      "length": 17,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 25,
      "content": "我便去找你 你便來找我 在哪裡遇見 就在那裡做 ",
      "length": 24,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 26,
      "content": "男人不汙不成器 ",
      "length": 8,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 27,
      "content": "請你當我手心裡的寶",
      "length": 9,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 28,
      "content": "你啥時候跟我做愛 心蛋糕 ",
      "length": 13,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 29,
      "content": "此生遇見你 盡用盡所有姿勢",
      "length": 13,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 30,
      "content": "我是預言家 今天我預測了你的身份 你是我喜歡的人 ",
      "length": 25,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 31,
      "content": "小心我用風油精塗你",
      "length": 9,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 32,
      "content": "皮皮鱔，快鑽 ",
      "length": 7,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 33,
      "content": "你瘦是因為你白天不能吃，晚上還挺能折騰 ",
      "length": 20,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 34,
      "content": "大漠孤煙我好直，長河落日你最圓。",
      "length": 16,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 35,
      "content": "將你摁在床上俯視著你，單手解開皮帶扣 ",
      "length": 19,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 36,
      "content": "精力是有限的,做愛做的事熱情是無限的",
      "length": 18,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 37,
      "content": "油嘴滑舌並非我本意 逗你開心才是我目的",
      "length": 19,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 38,
      "content": "趙兄，託你幫我辦點事！啥事？這件事嘛，就是你倒過來讀這句話",
      "length": 29,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 39,
      "content": "爾等凡夫俗子，當真不想嚐嚐仙女的滋味嗎？ ",
      "length": 21,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 40,
      "content": "誰和你談戀愛，我跟你過日子",
      "length": 13,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 41,
      "content": "你躺好，我來動",
      "length": 7,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 42,
      "content": "為經允許，擅自特別喜歡你，不好意思了。 ",
      "length": 20,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 43,
      "content": "你女朋友把我幾十億的孩子都吃了你說咋賠？ ",
      "length": 21,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 44,
      "content": "今晚一起玩個遊戲 叫你動我不動",
      "length": 15,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 45,
      "content": "我要拼上性命，成為你的人",
      "length": 12,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 46,
      "content": "穿他白襯衫蹭他",
      "length": 7,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 47,
      "content": "莪虆了，眞啲虆了 ",
      "length": 9,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 48,
      "content": "小擼怡情，大擼傷身，強擼灰飛煙滅 先撕長裙，後撕內褲，百撕不得其解 ",
      "length": 34,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 49,
      "content": "讓我佔有你 在你最好的年紀 ",
      "length": 14,
      "addedAt": "2026-03-22T18:17:56.403Z"
    },
    {
      "id": 50,
      "content": "你終會發現，你需要的並不是一個異性，而是一個可以溝通的靈魂。 ",
      "length": 31,
      "addedAt": "2026-03-22T18:17:56.403Z"
    }
  ]
