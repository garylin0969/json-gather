  "copywritings": [
    {
      "id": 1,
      "content": "生活中能拉你一把的是朋友，能拉你幾把的是老婆！",
      "length": 23,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 2,
      "content": "我喜歡你臉紅紅的樣子 更喜歡你氣喘吁吁的樣子 ",
      "length": 23,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 3,
      "content": "昨晚在我床上你可不是這麼說的 ",
      "length": 15,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 4,
      "content": "你是可愛的男孩 我是可愛",
      "length": 12,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 5,
      "content": "你這樣會被拖進小樹林的哦 ",
      "length": 13,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 6,
      "content": "前半生到處浪蕩，後半生為你煲湯。 ",
      "length": 17,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 7,
      "content": "你那麼傻，沒我怎麼辦 ",
      "length": 11,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 8,
      "content": "胃痛就喝酒 難受就自殘 心情不好就跳樓 別找我喜歡的人陪你 ",
      "length": 30,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 9,
      "content": "都是成年人我們就談點成年人的話題 很黃但不暴力，畢竟是法制社會 ",
      "length": 32,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 10,
      "content": "黑夜只有兩個好處， 睡你， 見到你。",
      "length": 18,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 11,
      "content": "愣著幹嘛 快來撩我啊 ",
      "length": 11,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 12,
      "content": "我交朋友不在乎她可愛不可愛 反正都沒你可愛 ",
      "length": 22,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 13,
      "content": "我的一生（身），是我能夠給你的最好禮物。",
      "length": 20,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 14,
      "content": "生活簡單 思想齷齪 每天除了幹你就是幹活 ",
      "length": 21,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 15,
      "content": "我之前沒有愛過別人，你是第一個，我怕我做得不好，讓你覺得愛情不過如此 ",
      "length": 35,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 16,
      "content": "姻緣有份，願你嫁我",
      "length": 9,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 17,
      "content": "外面超多情侶 我害怕 我一出現 他們就後悔自己已經有女朋友了",
      "length": 30,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 18,
      "content": "你那麼有趣，只跟你上床可惜了呀 ",
      "length": 16,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 19,
      "content": "能讓我著冰涼的手摸你滾燙的奶子嗎？ ",
      "length": 18,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 20,
      "content": "我的內心都是種子 甚至還想開車",
      "length": 15,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 21,
      "content": "你稍微記一下， 我找你的時候， 就是爆炸想你， 沒找你的時候， 就是憋著想你。 ",
      "length": 40,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 22,
      "content": "姿勢不對 起來重睡",
      "length": 9,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 23,
      "content": "我不信，除非我幹你一下 ",
      "length": 12,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 24,
      "content": "If I know what love is, it is because of you.",
      "length": 45,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 25,
      "content": "熬夜的癮和睡不到的你 ",
      "length": 11,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 26,
      "content": "姑娘，別傻了，世界上最愛你的男人已經娶了你媽了。",
      "length": 24,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 27,
      "content": "下雨天不打傘 溼身事小 淋病事大 ",
      "length": 17,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 28,
      "content": "肥=月巴（約吧） ",
      "length": 9,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 29,
      "content": "男人都是鱔變的 ",
      "length": 8,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 30,
      "content": "我跟你說過多少次了，抱怨沒用，你得抱我",
      "length": 19,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 31,
      "content": "這個星期日你有空麼 ",
      "length": 10,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 32,
      "content": "大家快救救我的孩子...算了...不救了...我自己用衛生紙擦吧",
      "length": 32,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 33,
      "content": "改日不如撞日遇到就要可勁日 ",
      "length": 14,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 34,
      "content": "我本來姓羅 遇見你之後我就幸福了",
      "length": 16,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 35,
      "content": "“以前沒覺得你這麼淫蕩”“我幾乎從來不綻放”",
      "length": 22,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 36,
      "content": "別看身體瘦，JJ全是肉",
      "length": 11,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 37,
      "content": "鋤禾日當午，當午說好！",
      "length": 11,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 38,
      "content": "這貓真白，哦不，這奶子真可愛 ",
      "length": 15,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 39,
      "content": "快來吧，我知道你想要什麼 ",
      "length": 13,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 40,
      "content": "等我一下，我先洗個頭再愛你",
      "length": 13,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 41,
      "content": "孩子跟你姓，我媽會游泳",
      "length": 11,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 42,
      "content": "山河有你",
      "length": 4,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 43,
      "content": "做愛做的事，交配交的人 ",
      "length": 12,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 44,
      "content": "對付你，一根手指就夠了！ ",
      "length": 13,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 45,
      "content": "睡覺調整動，免得有信息吵 ",
      "length": 13,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 46,
      "content": "再一次被幹醒了，真的很不喜歡這種感覺，每次被幹醒都難受，明天必須買個加溼器。 ",
      "length": 39,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 47,
      "content": "花前月下，不如花錢日下。",
      "length": 12,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 48,
      "content": "低調開房，文明叫床",
      "length": 9,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 49,
      "content": "天乾物燥，想找個洞喝點水，避避暑…",
      "length": 17,
      "addedAt": "2026-05-16T14:30:18.186Z"
    },
    {
      "id": 50,
      "content": "以前討厭女生吞吞吐吐的 現在發現還挺舒服的",
      "length": 21,
      "addedAt": "2026-05-16T14:30:18.186Z"
    }
  ]
