  "copywritings": [
    {
      "id": 1,
      "content": "管鮑之交 ",
      "length": 5,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 2,
      "content": "二十更更，三十夜夜，四十月月 ",
      "length": 15,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 3,
      "content": "不要抱怨，抱我 ",
      "length": 8,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 4,
      "content": "孫悟空：“嫂嫂你張開嘴，我要出來啦” ",
      "length": 19,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 5,
      "content": "“我拿這個瓶子打你的頭，哪個疼？”“我疼”“錯，我心疼” ",
      "length": 29,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 6,
      "content": "想邀請你來我家睡覺 畢竟我的床能睡兩個人.",
      "length": 21,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 7,
      "content": "深入淺出",
      "length": 4,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 8,
      "content": "你別想跑，就在這裡陪我吧！ ",
      "length": 14,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 9,
      "content": "去吧，皮卡丘",
      "length": 6,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 10,
      "content": "“猜猜我的心臟在哪邊？”“肯定左邊。”“錯 在你那邊。” ",
      "length": 29,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 11,
      "content": "沒什麼事就不能想你？",
      "length": 10,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 12,
      "content": "熬過了年少輕狂我們就天天上床我陪你精盡人亡",
      "length": 21,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 13,
      "content": "即使是想到你，也會讓我在我的腰下溼透",
      "length": 18,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 14,
      "content": "別說話，吻我 ",
      "length": 7,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 15,
      "content": "掀開熱被窩，就往腿上摸，掰開兩條腿，就往眼兒上擱。 答案：眼鏡 ",
      "length": 32,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 16,
      "content": "坐上來，自己動",
      "length": 7,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 17,
      "content": "我蹲在這裡不走等你找到我好不好，你快來呀我都要長蘑菇了",
      "length": 27,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 18,
      "content": "老子撲過來就是一個啪啪啪 ",
      "length": 13,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 19,
      "content": "做壞事早晚都會被發現 所以要中午做 ",
      "length": 18,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 20,
      "content": "“我真羨慕你”“羨慕什麼？”“你可以選擇不喜歡我，但我沒有選擇，我只能喜歡你”",
      "length": 39,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 21,
      "content": "都說男人用下體思考，看你這智商可不高啊 ",
      "length": 20,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 22,
      "content": "I want to spent all day in bed with you ",
      "length": 40,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 23,
      "content": "我愛你是真的 想餵你吃春藥也是真的 ",
      "length": 18,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 24,
      "content": "告訴你個秘密，正常人的心臟都在左邊，你猜我的心臟在哪邊？ 右邊？ 在你那邊！",
      "length": 38,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 25,
      "content": "春風十里 五十里 一百里 體測八百米 海底兩萬裡 德芙巧克力 香草味八喜 可可布朗尼 榴蓮菠蘿蜜 芝士玉米粒 雞汁土豆泥 黑椒牛裡脊 黃燜辣子雞 紅燒排骨醬醋魚 不如你 全都不如你",
      "length": 90,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 26,
      "content": "要不先嚐嘗我的中指 ",
      "length": 10,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 27,
      "content": "鈣氧鎢氧（CAOWO）",
      "length": 11,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 28,
      "content": "總之歲月漫長，然而值得等待 ",
      "length": 14,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 29,
      "content": "今晚別關窗 我想偷偷進你夢裡 ",
      "length": 15,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 30,
      "content": "太晚了宿舍要關門了",
      "length": 9,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 31,
      "content": "快來吧，我知道你想要什麼 ",
      "length": 13,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 32,
      "content": "為什麼哥哥會秒射，不會秒回？",
      "length": 14,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 33,
      "content": "如果有一天我老無所依 請把我丟到迪拜 撿垃圾 ",
      "length": 23,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 34,
      "content": "別人都想和你睡覺，我想陪你賴床",
      "length": 15,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 35,
      "content": "愛一個人是真心話 把想睡你說出口就是大冒險了 ",
      "length": 23,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 36,
      "content": "知道什麼叫胯下生風嗎 我這瓶風油精可以讓你知道 ",
      "length": 24,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 37,
      "content": "外面超多情侶 我害怕 我一出現 他們就後悔自己已經有女朋友了 ",
      "length": 31,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 38,
      "content": "你知道嗎，你笑起來很好看的，我一直都沒跟你說 ",
      "length": 23,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 39,
      "content": "“我要偷你的體溫” “說人話” “要抱抱”",
      "length": 21,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 40,
      "content": "“我要偷你的體溫” “說人話” “要抱抱” ",
      "length": 22,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 41,
      "content": "這一生可以愛很多人 但骨子裡最愛的只有一人 ",
      "length": 22,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 42,
      "content": "女神？就是屌絲把你放心上，而土豪把你放床上",
      "length": 21,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 43,
      "content": "老孃想打你左邊的蛋 就不會打倒你右邊的蛋 ",
      "length": 21,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 44,
      "content": "餘生裡有你，我就對餘生充滿期待 ",
      "length": 16,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 45,
      "content": "好久不見，腎是想念",
      "length": 9,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 46,
      "content": "你瘦是因為你白天不能吃，晚上還挺能折騰 ",
      "length": 20,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 47,
      "content": "所有人陪你顛沛流離，而我願意陪你在床上舒舒服服的做愛 ",
      "length": 27,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 48,
      "content": "算了這輩子就讓你蹂躪吧",
      "length": 11,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 49,
      "content": "我莫名奇妙的笑了，只正因想到了你",
      "length": 16,
      "addedAt": "2026-04-29T02:56:49.644Z"
    },
    {
      "id": 50,
      "content": "你要不要看我襯衣解開一扣 你要不要看我鎖骨往下一尺 你要不要床位讓我半米？ ????",
      "length": 42,
      "addedAt": "2026-04-29T02:56:49.644Z"
    }
  ]
